14.Implement Smote Method-Online MATLAB
MATLAB CODE:
% ---------------- LOAD DATA ----------------
data = readtable('WA_Fn-UseC_-Telco-Customer-Churn.csv');

% ---------------- REMOVE ID COLUMN ----------------
if ismember('customerID', data.Properties.VariableNames)
    data.customerID = [];
end

% ---------------- FIX TotalCharges ----------------
if ismember('TotalCharges', data.Properties.VariableNames)
    if iscell(data.TotalCharges) || isstring(data.TotalCharges)
        data.TotalCharges = string(data.TotalCharges);
        data.TotalCharges(data.TotalCharges == " " | data.TotalCharges == "") = "0";
        data.TotalCharges = str2double(data.TotalCharges);
    end
end

% Remove missing values
data = rmmissing(data);

% ---------------- ENCODE CATEGORICAL VARIABLES ----------------
for i = 1:width(data)
    if ~isnumeric(data.(i))
        data.(i) = grp2idx(categorical(data.(i)));
    end
end

% ---------------- SEPARATE FEATURES & TARGET ----------------
X = data{:,1:end-1};
y = data{:,end};

% ---------------- DISPLAY ORIGINAL DISTRIBUTION ----------------
disp("Before SMOTE:");
tabulate(y)

% ---------------- SMOTE FUNCTION ----------------
function [X_new, y_new] = simple_smote(X, y, k)

    % Find minority class
    classes = unique(y);
    counts = histc(y, classes);
    [~, idx] = min(counts);
    minority_class = classes(idx);

    majority_class = classes(classes ~= minority_class);

    X_min = X(y == minority_class, :);
    X_maj = X(y == majority_class, :);

    n_min = size(X_min,1);
    n_maj = size(X_maj,1);

    % Number of synthetic samples needed
    n_to_generate = n_maj - n_min;

    % Find neighbors
    neighbors = knnsearch(X_min, X_min, 'K', k+1);

    synthetic = [];

    % Generate only required samples
    for i = 1:n_to_generate
        idx_i = randi(n_min);
        nn = neighbors(idx_i, randi([2 k+1]));

        diff = X_min(nn,:) - X_min(idx_i,:);
        gap = rand(1, size(X,2));

        synthetic_point = X_min(idx_i,:) + gap .* diff;
        synthetic = [synthetic; synthetic_point];
    end

    % Combine
    X_new = [X; synthetic];
    y_new = [y; repmat(minority_class, size(synthetic,1),1)];
end
% ---------------- APPLY SMOTE ----------------
[X_sm, y_sm] = simple_smote(X, y, 5);

% ---------------- DISPLAY AFTER SMOTE ----------------
disp("After SMOTE:");
tabulate(y_sm)

% ---------------- PLOTS ----------------

% Adjust indices if needed based on dataset
tenure = X(:,1);
monthly = X(:,end);

figure;
gscatter(tenure, monthly, y);
title('Before SMOTE');
xlabel('Tenure');
ylabel('Monthly Charges');

figure;
